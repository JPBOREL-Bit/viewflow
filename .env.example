# Copiá este archivo a ".env" (sin .example) y completá tus valores reales.
# El archivo ".env" NUNCA se sube a git ni se sirve al navegador.

# Puerto del servidor
PORT=3000

# Secreto para firmar las sesiones (JWT). Generá uno random y no lo compartas.
# Podés generarlo con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambiar_por_un_valor_random_largo

# Credenciales del único administrador. Se usan SOLO la primera vez que
# arranca el servidor, para crear la cuenta admin (con la contraseña ya
# hasheada). Después de eso podés borrar estas líneas si querés.
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=una_contraseña_fuerte_acá

# Dominio del frontend en producción (para CORS). En desarrollo local podés
# dejarlo vacío.
CLIENT_ORIGIN=

NODE_ENV=development

# OPCIONAL — envío automático del código de verificación por Gmail.
# Si dejás estas dos vacías, todo sigue funcionando igual: el código queda
# disponible en el panel de admin ("Verificación") para que lo mandes vos a
# mano, como hasta ahora.
#
# Para activarlo:
# 1. Usá una cuenta de Gmail (puede ser la del negocio).
# 2. Activá la verificación en 2 pasos en esa cuenta de Google.
# 3. Generá una "contraseña de aplicación" en myaccount.google.com/apppasswords
#    (NO uses tu contraseña normal de Gmail acá, usa esa contraseña especial).
# 4. Pegá esos valores abajo.
GMAIL_USER=
GMAIL_APP_PASSWORD=
